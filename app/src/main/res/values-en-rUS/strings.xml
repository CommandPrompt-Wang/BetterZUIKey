    <string name="agreement_title">Terms of Use</string>
    <string name="agreement_header">⚠ Please Read the Help Documentation</string>
    <string name="agreement_body">BetterZUIKey is an Xposed module that modifies keyboard shortcut behavior by hooking into the system keyboard shortcut processing logic.\n\nThis module is intended solely for personal learning and research. Please fully understand the implications of each option before use. Improper configuration may cause abnormal behavior in some system shortcuts.\n\nThe developer assumes no responsibility for any system failures, data loss, or device anomalies resulting from the use of this module.\nBy using this module, you acknowledge that you have read, understood, and accepted these terms.</string>
    <string name="agreement_btn_read_doc">Read Documentation</string>
    <string name="agreement_btn_exit">Exit</string>
    <string name="agreement_btn_close">Close</string>

